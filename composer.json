{
    "name": "knivey/amphp-openai",
    "type": "library",
    "require": {
        "php": "^8.5",
        "amphp/http-client": "^5.0",
        "amphp/byte-stream": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Knivey\\OpenAi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Knivey\\OpenAi\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse",
        "cs:check": "php-cs-fixer check",
        "cs:fix": "php-cs-fixer fix",
        "check": [
            "@stan",
            "@cs:check",
            "@test"
        ]
    },
    "authors": [
        {
            "name": "knivey",
            "email": "knivey@botops.net"
        }
    ]
}
